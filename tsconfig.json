{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@domain/*": ["src/domain/*"],
      "@data/*": ["src/data/*"],
      "@presentation/*": ["src/presentation/*"],
      "@di/*": ["src/di/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/**/*", "index.ts", "App.tsx"]
}
